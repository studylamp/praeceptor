# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Provider API keys (only the ones you actually use) ---
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# --- App secrets ---
# Parent/admin console password.
ADMIN_PASSWORD=change-me
# Session cookie signing secret. Generate a long random string, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET=change-me-to-a-long-random-string

# --- Networking (docker-compose) ---
# Bind the container's port to THIS LAN address only. Never 0.0.0.0, never port-forward.
# Set it to your server's LAN IP so other devices on the network can reach it.
# Find it on the server with:  hostname -I   (or `ip addr`).
# Leaving this unset makes docker-compose abort (it will NOT fall back to 0.0.0.0).
# Use 127.0.0.1 only if the browser runs on the server itself.
#
# Behind a reverse proxy? Even if you comment out the compose `ports:` mapping to serve
# only through the proxy, still set BIND_ADDR to your server's LAN IP so the tools
# boot-guard reflects intent (it keys off this string, not a live socket).
BIND_ADDR=192.168.1.10

# Host port to publish on (must be a plain number). Change it if 8000 is already used by
# another container/service on this host — then browse to http://<BIND_ADDR>:<HOST_PORT>.
# The app always listens on 8000 *inside* the container; this only changes the host side.
HOST_PORT=8000

# Set true when a TLS-terminating reverse proxy (e.g. Nginx Proxy Manager) fronts the
# app, so the session cookie is marked Secure. Leave false for plain-HTTP LAN-by-IP.
SESSION_HTTPS_ONLY=false

# Optional: source-code URL for the admin "Source on GitHub" footer link. Defaults to the
# upstream repo (github.com/studylamp/praeceptor). Uncomment to point at your own fork, or
# set it empty (PROJECT_URL=) to hide the link.
# PROJECT_URL=https://github.com/your-org/praeceptor

# Optional: build/version string baked into the image (shown in the admin footer and at
# /healthz). Normally you DON'T set this here — pass it at build time so it reflects the
# checked-out commit, e.g.:
#   APP_VERSION=$(git describe --tags --always --dirty) docker compose up -d --build
# Uncomment to pin a fixed value instead. Defaults to "dev" when unset.
# APP_VERSION=

# --- Model defaults (LiteLLM model strings) ---
# Usually leave these; per-subject tutor model is editable in the admin console.
GATE_MODEL=anthropic/claude-haiku-4-5
TUTOR_MODEL_DEFAULT=anthropic/claude-sonnet-5

# --- Default daily caps pre-filled on the new-student form (cost control) ---
# A parent can change or clear them per student in admin (blank = no cap). The token cap
# is the real spend control; the message cap guards against spam/loops.
DEFAULT_DAILY_MESSAGE_CAP=200
DEFAULT_DAILY_TOKEN_CAP=300000

# --- Computation tools / sandboxed code execution ---
# The tutor can run sandboxed Python (sympy/numpy/matplotlib) to compute & verify math
# and draw plots. Enabled per-subject in the admin console; this is the global switch.
TOOLS_ENABLED=true
# Max tool rounds per tutor turn (bounds latency/cost).
TOOL_MAX_ROUNDS=5
# Per-call sandbox limits.
SANDBOX_TIMEOUT=8
SANDBOX_MEM_MB=1024
#
# ISOLATION (Docker): tool code runs in a SEPARATE, network-isolated `sandbox` container.
# docker-compose.yml sets SANDBOX_SERVER=/ipc/sandbox.sock and runs that worker for you, so
# you don't need to set anything here — it just works with `docker compose up -d`, no host
# changes, no security_opt. The app refuses to boot on a non-loopback bind if NO isolation
# is configured (neither the worker nor a local wrapper).
# SANDBOX_MAX_CONCURRENT=4      # max concurrent tool executions in the worker container
#
# ISOLATION (bare-metal / no Docker): leave SANDBOX_SERVER unset and optionally set a local
# OS wrapper so tool code still can't reach the network or the filesystem, e.g.:
# SANDBOX_WRAPPER=firejail --quiet --net=none --private
