*.sql
*.part

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Deploy artifacts (built on demand, never committed)
*.tar.gz
*.tgz

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local-only working notes — never committed
PLAN.md

# Local scratch / temp workspace — never committed
.tmp/

# Local deployment overrides (Compose auto-merges this) — never committed
docker-compose.override.yml
